{
  "name": "@wexio/messenger-widget-angular",
  "version": "1.0.24",
  "description": "Angular standalone component embed for the Wexio web messenger. Thin wrapper around the <wexio-widget> custom element — same WidgetShell runtime, same Shadow-DOM isolation.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/fesm2022/wexio-messenger-widget-angular.mjs",
  "module": "fesm2022/wexio-messenger-widget-angular.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./fesm2022/wexio-messenger-widget-angular.mjs",
      "esm2022": "./esm2022/wexio-messenger-widget-angular.mjs",
      "esm": "./esm2022/wexio-messenger-widget-angular.mjs"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "files": [
    "dist/fesm2022",
    "dist/esm2022",
    "dist/*.d.ts",
    "dist/*.d.mts",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "@angular/common": ">=16.0.0",
    "@angular/core": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wexiohub/messenger-widget-angular.git"
  },
  "homepage": "https://github.com/wexiohub/messenger-widget-angular#readme",
  "bugs": {
    "url": "https://github.com/wexiohub/messenger-widget-angular/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "typings": "index.d.ts",
  "sideEffects": false
}